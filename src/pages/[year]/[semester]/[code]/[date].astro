---
import { getCollection, getEntry, render } from "astro:content";
import StarlightPage, { type StarlightPageProps } from "@astrojs/starlight/components/StarlightPage.astro";
import type { GetStaticPaths } from "astro";

getEntry;

export const getStaticPaths: GetStaticPaths = async () => {
  const lessons = await getCollection("docs");
  return lessons.map((l) => {
    const parts = l.id.split("/");
    return { params: { year: parts[0], semester: parts[1], code: parts[2], date: parts[3] } };
  });
};

const { year, semester, code, date } = Astro.params;
const id = `${year}/${semester}/${code}/${date}`;
const lesson = await getEntry("docs", id);
if (!lesson) throw new Error(`lesson '${id}' not found`);

const rendered = await render(lesson);
// biome-ignore lint/suspicious/noExplicitAny: Some restriction on types get lost somewhere.
const frontmatter: StarlightPageProps["frontmatter"] = rendered.remarkPluginFrontmatter as any;
const Content = rendered.Content;
---

<!--
    This page renders the lesson like Starlight would, but it sets the correct
    lang for each one, as specified in the frontmatter
-->
<StarlightPage {frontmatter} headings={rendered.headings} lang={lesson.data.lang}>
  <Content />
</StarlightPage>
